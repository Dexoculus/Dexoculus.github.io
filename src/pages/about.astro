---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { profile } from "@/lib/content";
---

<BaseLayout title="CV | Hyeonbin Han" description="Curriculum vitae and research profile for Hyeonbin Han.">
  <section class="page-hero cv-hero shell">
    <div class="cv-hero-content">
      <p class="section-kicker">CURRICULUM VITAE</p>
      <h1>{profile.name}</h1>
      <p class="cv-role">{profile.role}</p>
      <p>{profile.summary}</p>
      <p class="cv-location">{profile.location}</p>
      <div class="link-row">
        {profile.links.map((link) => <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>)}
        <a href={`mailto:${profile.email}`}>Email</a>
        <a class="button secondary print-button" href="/assets/CV.pdf" download>Download CV</a>
      </div>
    </div>
  </section>

  <section class="shell cv-grid">
    <article class="info-panel">
      <p class="section-kicker">EDUCATION</p>
      <h2>{profile.education.school}</h2>
      <p>{profile.education.program}</p>
      <dl class="detail-list">
        <div><dt>Period</dt><dd>{profile.education.period}</dd></div>
        <div><dt>Record</dt><dd>{profile.education.detail}</dd></div>
        <div><dt>Location</dt><dd>{profile.education.location}</dd></div>
      </dl>
    </article>

    <article class="dark-panel">
      <p class="section-kicker">FOCUS</p>
      <h2>Research interests</h2>
      <div class="chip-grid">
        {profile.researchInterests.map((item) => <span>{item}</span>)}
      </div>
    </article>
  </section>

  <section class="shell resume-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">EXPERIENCE</p>
        <h2>Research experience</h2>
      </div>
    </div>
    <div class="experience-stack">
      {
        profile.experience.map((item) => (
          <article class="resume-item">
            <div>
              <span>{item.period}</span>
              <h3>
                {
                  item.organizationUrl ? (
                    <a class="inline-link" href={item.organizationUrl} target="_blank" rel="noreferrer">
                      {item.organization}
                    </a>
                  ) : (
                    item.organization
                  )
                }
              </h3>
              <p>{item.role}</p>
              <p class="resume-location">{item.location}</p>
            </div>
            <ul>
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="shell cv-output-grid">
    <article class="info-panel">
      <p class="section-kicker">PUBLICATION</p>
      <h2>Journal article</h2>
      <ul class="plain-list">
        {profile.publications.map((item) => <li>{item}</li>)}
      </ul>
    </article>
    <article class="info-panel">
      <p class="section-kicker">CONFERENCES</p>
      <h2>Presentations</h2>
      <ul class="plain-list">
        {profile.presentations.map((item) => <li>{item}</li>)}
      </ul>
    </article>
    <article class="info-panel">
      <p class="section-kicker">HONORS</p>
      <h2>Awards</h2>
      <ul class="plain-list">
        {profile.awards.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </section>

  <section class="shell resume-section">
    <div class="section-head">
      <div>
        <p class="section-kicker">TECHNICAL SKILLS</p>
        <h2>Research and engineering stack</h2>
      </div>
    </div>
    <div class="info-panel cv-skills-panel">
      <p class="section-kicker">SKILLS</p>
      <div class="skill-categories">
        {
          profile.skillGroups.map((group) => (
            <section class="skill-group">
              <header>
                <h3>{group.label}</h3>
                <span>{group.scope}</span>
              </header>
              <div class="chip-grid">
                {group.items.map((item) => <span>{item}</span>)}
              </div>
            </section>
          ))
        }
      </div>
    </div>
  </section>

  <section class="shell cv-project-route">
    <div>
      <p class="section-kicker">PROJECT RECORD</p>
      <h2>Project work is maintained separately.</h2>
      <p>Detailed systems, implementation notes, media, and deployment results are collected in the Projects archive.</p>
    </div>
    <a class="button primary" href="/projects/">Open projects</a>
  </section>
</BaseLayout>

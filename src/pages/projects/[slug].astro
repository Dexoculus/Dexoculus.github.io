---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArticleToc from "@/components/ArticleToc.astro";
import CodeCopyRuntime from "@/components/CodeCopyRuntime.astro";
import ProjectMedia from "@/components/ProjectMedia.astro";
import { projects } from "@/lib/content";
import { absoluteUrl } from "@/lib/seo";

export function getStaticPaths() {
  return projects.map((project) => ({ params: { slug: project.slug } }));
}

const project = projects.find((item) => item.slug === Astro.params.slug);
if (!project) throw new Error(`Project not found: ${Astro.params.slug}`);
const Content = project.Content;
const MathStyles = project.richFeatures.math ? (await import("@/components/MathStyles.astro")).default : null;
const ChartRuntime = project.richFeatures.chart ? (await import("@/components/ChartRuntime.astro")).default : null;
const hasToc = project.headings.length > 0;
const projectJsonLd = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: project.name,
  description: project.description,
  url: absoluteUrl(`/projects/${project.slug}/`),
  sameAs: project.externalUrl
};
---

<BaseLayout title={`${project.name} | Hyeonbin Han`} description={project.description} type="article" image={project.image} jsonLd={projectJsonLd}>
  {MathStyles && <MathStyles slot="head" />}
  <article class="shell detail-layout">
    <header class="record-header">
      <div>
        <p class="section-kicker">PROJECT {String(project.sequence).padStart(2, "0")}</p>
        <h1>{project.name}</h1>
        <p>{project.description}</p>
        <div class="tag-row large">
          {project.tools.map((tool) => <span>{tool}</span>)}
        </div>
      </div>
      <ProjectMedia project={project} large />
    </header>
    <div class:list={["article-body", { "no-toc": !hasToc }]}>
      <ArticleToc headings={project.headings} />
      <div class="markdown-panel">
        {typeof Content === "function" ? <Content /> : <p>{project.description}</p>}
        {project.externalUrl && <p><a class="button primary" href={project.externalUrl} target="_blank" rel="noreferrer">Open project</a></p>}
      </div>
    </div>
  </article>
  {ChartRuntime && <ChartRuntime slot="runtimes" />}
  <CodeCopyRuntime slot="runtimes" />
</BaseLayout>

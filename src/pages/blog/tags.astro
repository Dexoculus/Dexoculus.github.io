---
import PostCard from "@/components/PostCard.astro";
import TagFilterList from "@/components/TagFilterList.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { posts } from "@/lib/content";

const tags = Array.from(new Set(posts.flatMap((post) => post.tags))).sort();
const tagCounts = tags.map((tag) => ({
  tag,
  id: tag.toLowerCase().replace(/[^a-z0-9]+/g, "-"),
  count: posts.filter((post) => post.tags.includes(tag)).length
}));
---

<BaseLayout title="Tags | Hyeonbin Han" description="Filter technical notes by tag.">
  <section class="page-hero shell">
    <p class="section-kicker">NOTE INDEX</p>
    <h1>Tags</h1>
    <p>Select a tag to filter the notes archive without repeating the same article across multiple sections.</p>
  </section>

  <section class="shell tag-filter-panel" aria-label="Filter notes by tag">
    <div class="tag-filter-head">
      <div>
        <p class="section-kicker">FILTER</p>
        <h2>Tags</h2>
      </div>
      <span id="tag-filter-count">{posts.length} notes</span>
    </div>
    <TagFilterList tags={tagCounts} total={posts.length} listId="archive-tag-filter" />
  </section>

  <section class="shell note-grid archive tag-filter-results">
    {posts.map((post) => <PostCard post={post} />)}
  </section>

  <script>
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-tag-filter]"));
    const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-note-card]"));
    const count = document.querySelector("#tag-filter-count");

    function normalizeTag(value: string) {
      return value.trim().toLowerCase();
    }

    function applyTagFilter(tag: string, updateHash = true) {
      const selected = normalizeTag(tag || "all");
      let visible = 0;

      for (const button of buttons) {
        const isActive = normalizeTag(button.dataset.tagFilter || "all") === selected;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      }

      for (const card of cards) {
        const tags = (card.dataset.tags || "").split("|");
        const isVisible = selected === "all" || tags.includes(selected);
        card.hidden = !isVisible;
        if (isVisible) visible += 1;
      }

      if (count) count.textContent = `${visible} ${visible === 1 ? "note" : "notes"}`;

      if (updateHash) {
        const activeButton = buttons.find((button) => normalizeTag(button.dataset.tagFilter || "all") === selected);
        const id = activeButton?.dataset.tagId;
        history.replaceState(null, "", selected === "all" || !id ? location.pathname : `#${id}`);
      }
    }

    buttons.forEach((button) => {
      button.addEventListener("click", () => applyTagFilter(button.dataset.tagFilter || "all"));
    });

    const hash = decodeURIComponent(location.hash.replace(/^#/, ""));
    const initial = buttons.find((button) => button.dataset.tagId === hash)?.dataset.tagFilter || "all";
    applyTagFilter(initial, false);
  </script>
</BaseLayout>

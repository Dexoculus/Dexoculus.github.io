---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { posts, profile, projects } from "@/lib/content";

const featuredProjects = projects.slice(0, 3);
const featuredPosts = posts.slice(0, 3);
---

<BaseLayout
  title="Hyeonbin Han | Robotics, Vision, and Data"
  description="Research projects, engineering work, and technical notes in robotics, computer vision, physical AI, and data science."
>
  <section class="hero site-hero shell">
    <div class="hero-copy site-intro">
      <p class="section-kicker">RESEARCH / ENGINEERING / NOTES</p>
      <h1 class="sr-only">Hyeonbin Han robotics, vision, and data science portfolio</h1>
      <figure class="hero-media-statement">
        <img
          src="/assets/hero-robot-cool.webp"
          alt="A dramatic robot cockpit scene used as the homepage visual statement."
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </figure>
      <p class="hero-role">Robotics, computer vision, physical AI, and data science.</p>
      <p class="hero-summary">
        A working archive of selected systems, research output, implementation notes, and technical experiments maintained by {profile.name}.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/projects/">Explore projects</a>
        <a class="button secondary" href="/blog/">Read notes</a>
      </div>
      <dl class="signal-grid">
        <div>
          <dt>Projects</dt>
          <dd>{projects.length} documented systems</dd>
        </div>
        <div>
          <dt>Notes</dt>
          <dd>{posts.length} technical entries</dd>
        </div>
        <div>
          <dt>Profile</dt>
          <dd><a class="inline-link" href="/about/">CV and research record</a></dd>
        </div>
      </dl>
    </div>
    <aside class="ops-panel site-directory">
      <div class="ops-header">
        <span>SITE INDEX</span>
        <strong>001</strong>
      </div>
      <nav class="directory-list" aria-label="Site sections">
        <a href="/projects/">
          <span>01</span>
          <strong>Projects</strong>
          <small>Robotics, vision, ML, and deployed systems</small>
        </a>
        <a href="/blog/">
          <span>02</span>
          <strong>Notes</strong>
          <small>Research logs, case reports, and implementation guides</small>
        </a>
        <a href="/about/">
          <span>03</span>
          <strong>CV</strong>
          <small>Education, experience, publications, and awards</small>
        </a>
      </nav>
      <div class="site-owner">
        <span>Maintained by</span>
        <strong>{profile.name}</strong>
        <small>{profile.location}</small>
      </div>
    </aside>
  </section>

  <section class="shell section-grid">
    <div class="section-head wide">
      <div>
        <p class="section-kicker">PROJECTS</p>
        <h2>Selected Projects</h2>
      </div>
      <a class="button text" href="/projects/">All projects</a>
    </div>
    <div class="project-grid home-feature-grid">
      {featuredProjects.map((project) => <ProjectCard project={project} compact />)}
    </div>
  </section>

  <section class="shell section-grid">
    <div class="section-head wide">
      <div>
        <p class="section-kicker">WRITING</p>
        <h2>Notes</h2>
      </div>
      <a class="button text" href="/blog/">All notes</a>
    </div>
    <div class="note-grid home-feature-grid">
      {featuredPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>

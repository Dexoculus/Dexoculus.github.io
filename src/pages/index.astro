---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { homeContent } from "@/data/home";
import { posts, profile, projects } from "@/lib/content";

const featuredProjects = projects
  .filter((project) => project.featured)
  .sort((a, b) => a.featuredOrder - b.featuredOrder || b.sequence - a.sequence);
const featuredPosts = posts
  .filter((post) => post.featured)
  .sort((a, b) => a.featuredOrder - b.featuredOrder || a.title.localeCompare(b.title));
---

<BaseLayout title={homeContent.meta.title} description={homeContent.meta.description}>
  <section class="hero site-hero shell">
    <div class="hero-copy site-intro">
      <p class="section-kicker">{homeContent.hero.kicker}</p>
      <h1 class="sr-only">{homeContent.hero.hiddenTitle}</h1>
      <figure class="hero-media-statement">
        <img
          src={homeContent.hero.image}
          alt={homeContent.hero.imageAlt}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </figure>
      <p class="hero-role">{homeContent.hero.role}</p>
      <p class="hero-summary">
        {homeContent.hero.summaryPrefix} {profile.name}.
      </p>
      <div class="hero-actions">
        {homeContent.actions.map((action) => <a class={`button ${action.variant}`} href={action.href}>{action.label}</a>)}
      </div>
      <dl class="signal-grid">
        <div>
          <dt>{homeContent.stats.projectsLabel}</dt>
          <dd>{projects.length} {homeContent.stats.projectsSuffix}</dd>
        </div>
        <div>
          <dt>{homeContent.stats.notesLabel}</dt>
          <dd>{posts.length} {homeContent.stats.notesSuffix}</dd>
        </div>
        <div>
          <dt>{homeContent.stats.profileLabel}</dt>
          <dd><a class="inline-link" href={homeContent.stats.profileHref}>{homeContent.stats.profileText}</a></dd>
        </div>
      </dl>
    </div>
    <aside class="ops-panel site-directory">
      <div class="ops-header">
        <span>{homeContent.directory.eyebrow}</span>
        <strong>{homeContent.directory.code}</strong>
      </div>
      <nav class="directory-list" aria-label="Site sections">
        {
          homeContent.directory.items.map((item) => (
            <a href={item.href}>
              <span>{item.number}</span>
              <strong>{item.label}</strong>
              <small>{item.description}</small>
            </a>
          ))
        }
      </nav>
      <div class="site-owner">
        <span>{homeContent.directory.ownerLabel}</span>
        <strong>{profile.name}</strong>
        <small>{profile.location}</small>
      </div>
    </aside>
  </section>

  {
    featuredProjects.length > 0 && (
      <section class="shell section-grid">
        <div class="section-head wide">
          <div>
            <p class="section-kicker">{homeContent.sections.projects.kicker}</p>
            <h2>{homeContent.sections.projects.title}</h2>
          </div>
          <a class="button text" href={homeContent.sections.projects.actionHref}>{homeContent.sections.projects.actionLabel}</a>
        </div>
        <div class="project-grid home-feature-grid">
          {featuredProjects.map((project) => <ProjectCard project={project} compact />)}
        </div>
      </section>
    )
  }

  {
    featuredPosts.length > 0 && (
      <section class="shell section-grid">
        <div class="section-head wide">
          <div>
            <p class="section-kicker">{homeContent.sections.notes.kicker}</p>
            <h2>{homeContent.sections.notes.title}</h2>
          </div>
          <a class="button text" href={homeContent.sections.notes.actionHref}>{homeContent.sections.notes.actionLabel}</a>
        </div>
        <div class="note-grid home-feature-grid">
          {featuredPosts.map((post) => <PostCard post={post} />)}
        </div>
      </section>
    )
  }
</BaseLayout>

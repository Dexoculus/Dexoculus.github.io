---
type Props = {
  name: string;
  percentage: number;
};

const { name, percentage } = Astro.props;
const bounded = Math.max(0, Math.min(100, Number(percentage) || 0));
---

<div class="skill-row">
  <div>
    <strong>{name}</strong>
    <span>{bounded}%</span>
  </div>
  <i style={`--value: ${bounded}%`}></i>
</div>

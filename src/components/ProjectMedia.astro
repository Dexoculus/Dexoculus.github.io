---
import type { Post, Project } from "@/lib/content";

type Props = {
  project: Project | Post;
  actionLabel?: string;
  large?: boolean;
  autoplayPreview?: boolean;
};

const { project, actionLabel, large = false, autoplayPreview = true } = Astro.props;
const mediaLabel = "name" in project ? project.name : project.title;
const mediaUrl = project.mediaUrl || project.image;
const mediaAction = actionLabel || undefined;
const isVideo = project.mediaType === "video";
const canVideoFallback = Boolean(mediaUrl && !isVideo && mediaUrl.includes("github.com/user-attachments/assets/"));
const poster = isVideo ? project.image : undefined;
const shouldRenderVideo = isVideo && (large || autoplayPreview);
const isProject = "tools" in project;
const placeholderLabel = isProject ? "PROJECT RECORD" : "NOTE RECORD";
const placeholderTools = isProject ? project.tools.slice(0, 3) : project.tags.slice(0, 3);
---

<div class:list={["project-media", { large }]} data-media-action={mediaAction}>
  {
    mediaUrl ? (
      shouldRenderVideo ? (
        <video
          src={mediaUrl}
          data-video-autoplay=""
          data-video-preview={!large ? "" : undefined}
          aria-label={`${mediaLabel} video preview`}
          autoplay={!large}
          controls={large}
          loop
          muted
          playsinline
          preload="metadata"
          poster={poster}
        />
      ) : isVideo && poster ? (
        <img src={poster} alt="" loading="lazy" decoding="async" fetchpriority="low" />
      ) : (
        <>
          <img
            src={mediaUrl}
            alt={large ? `${mediaLabel} project media` : ""}
            loading={large ? undefined : "lazy"}
            decoding="async"
            fetchpriority={large ? "high" : "low"}
            data-video-fallback={canVideoFallback ? "github-attachment" : undefined}
          />
          {
            canVideoFallback && (
              <video
                class="project-media-fallback"
                data-preview-src={mediaUrl}
                data-video-autoplay=""
                data-video-preview=""
                aria-label={`${mediaLabel} video preview`}
                autoplay={!large}
                controls={large}
                hidden
                loop
                muted
                playsinline
                preload="none"
                poster={project.image}
              />
            )
          }
        </>
      )
    ) : (
      <div class:list={["project-record-art", { large }]}>
        <span>{placeholderLabel}</span>
        <strong>{mediaLabel}</strong>
        {placeholderTools.length > 0 && <small>{placeholderTools.join(" / ")}</small>}
      </div>
    )
  }
  {isVideo && !shouldRenderVideo && <span class="media-play-indicator" aria-hidden="true"></span>}
</div>

<script>
  const visibleVideos = new WeakSet<HTMLVideoElement>();
  let videoObserver: IntersectionObserver | undefined;
  let videoSyncFrame = 0;

  function hydratePreview(video: HTMLVideoElement) {
    if (video.src || !video.dataset.previewSrc) return;
    video.src = video.dataset.previewSrc;
    video.load();
  }

  function prepareVideo(video: HTMLVideoElement) {
    video.muted = true;
    video.defaultMuted = true;
    video.playsInline = true;
    hydratePreview(video);
  }

  function playVideo(video: HTMLVideoElement) {
    if (video.hidden || document.hidden) return;
    prepareVideo(video);
    video.play()
      .then(() => {
        delete video.dataset.videoBlocked;
      })
      .catch(() => {
        video.dataset.videoBlocked = "true";
      });
  }

  function pauseVideo(video: HTMLVideoElement) {
    video.pause();
  }

  function syncVisibleVideo(video: HTMLVideoElement) {
    if (visibleVideos.has(video)) {
      playVideo(video);
    } else {
      pauseVideo(video);
    }
  }

  function isInViewport(video: HTMLVideoElement) {
    const rect = video.getBoundingClientRect();
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
    const viewportWidth = window.innerWidth || document.documentElement.clientWidth;
    return rect.width > 0 && rect.height > 0 && rect.bottom > 0 && rect.right > 0 && rect.top < viewportHeight && rect.left < viewportWidth;
  }

  function getVideoObserver() {
    if (videoObserver) return videoObserver;
    videoObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const video = entry.target;
          if (!(video instanceof HTMLVideoElement)) return;
          if (entry.isIntersecting && entry.intersectionRatio > 0) {
            visibleVideos.add(video);
          } else {
            visibleVideos.delete(video);
          }
          syncVisibleVideo(video);
        });
      },
      {
        rootMargin: "80px 0px",
        threshold: [0, 0.01, 0.18, 0.55],
      }
    );
    return videoObserver;
  }

  function syncInitialVisibility(video: HTMLVideoElement) {
    if (isInViewport(video)) {
      visibleVideos.add(video);
    } else {
      visibleVideos.delete(video);
    }
    syncVisibleVideo(video);
  }

  function observeVideo(video: HTMLVideoElement) {
    if (video.dataset.autoplayBound === "true") return;
    video.dataset.autoplayBound = "true";
    prepareVideo(video);

    video.addEventListener("pointerenter", () => playVideo(video));
    video.addEventListener("click", () => playVideo(video));
    video.addEventListener("touchstart", () => playVideo(video), { passive: true });

    if (!("IntersectionObserver" in window)) {
      playVideo(video);
      return;
    }

    getVideoObserver().observe(video);
    requestAnimationFrame(() => syncInitialVisibility(video));
    window.setTimeout(() => syncInitialVisibility(video), 160);
  }

  function bindProjectMediaFallbacks() {
    document.querySelectorAll<HTMLImageElement>("img[data-video-fallback]:not([data-fallback-bound])").forEach((image) => {
      image.dataset.fallbackBound = "true";
      image.addEventListener(
        "error",
        () => {
          const fallback = image.nextElementSibling;
          if (!(fallback instanceof HTMLVideoElement)) return;
          image.hidden = true;
          fallback.hidden = false;
          prepareVideo(fallback);
          observeVideo(fallback);
          if (isInViewport(fallback)) {
            visibleVideos.add(fallback);
          }
          syncVisibleVideo(fallback);
        },
        { once: true }
      );
    });
  }

  function bindVideoPreviews() {
    document.querySelectorAll<HTMLVideoElement>("video[data-video-autoplay]").forEach((video) => {
      observeVideo(video);
    });
  }

  function syncAllVisibleVideos() {
    document.querySelectorAll<HTMLVideoElement>("video[data-video-autoplay]").forEach((video) => {
      if (isInViewport(video)) {
        visibleVideos.add(video);
      } else {
        visibleVideos.delete(video);
      }
      syncVisibleVideo(video);
    });
  }

  function scheduleVideoSync() {
    if (videoSyncFrame) return;
    videoSyncFrame = window.requestAnimationFrame(() => {
      videoSyncFrame = 0;
      syncAllVisibleVideos();
    });
  }

  function bindProjectMedia() {
    bindProjectMediaFallbacks();
    bindVideoPreviews();
    scheduleVideoSync();
  }

  bindProjectMedia();

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bindProjectMedia, { once: true });
  } else {
    requestAnimationFrame(bindProjectMedia);
  }

  window.addEventListener("load", bindProjectMedia, { once: true });
  window.setTimeout(bindProjectMedia, 320);
  window.setTimeout(bindProjectMedia, 1000);
  window.addEventListener("scroll", scheduleVideoSync, { passive: true });
  window.addEventListener("resize", scheduleVideoSync);

  document.addEventListener("visibilitychange", () => {
    syncAllVisibleVideos();
  });
  document.addEventListener("astro:page-load", bindProjectMedia);
</script>

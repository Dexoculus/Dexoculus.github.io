---
import type { Post, Project } from "@/lib/content";

type Props = {
  project: Project | Post;
  badge?: string;
  large?: boolean;
};

const { project, badge, large = false } = Astro.props;
const mediaLabel = "name" in project ? project.name : project.title;
const mediaUrl = project.mediaUrl || project.image;
const isVideo = project.mediaType === "video";
const canVideoFallback = Boolean(mediaUrl && !isVideo && mediaUrl.includes("github.com/user-attachments/assets/"));
const poster = isVideo ? project.image : undefined;
const previewSrc = !large && isVideo ? mediaUrl : undefined;
---

<div class:list={["project-media", { large }]}>
  {
    mediaUrl ? (
      isVideo ? (
        <video
          src={large ? mediaUrl : undefined}
          data-preview-src={previewSrc}
          data-video-autoplay=""
          data-video-preview={!large ? "" : undefined}
          aria-label={`${mediaLabel} video preview`}
          controls={large}
          loop
          muted
          playsinline
          preload={large ? "metadata" : "none"}
          poster={poster}
        />
      ) : (
        <>
          <img src={mediaUrl} alt="" loading={large ? undefined : "lazy"} data-video-fallback={canVideoFallback ? "github-attachment" : undefined} />
          {
            canVideoFallback && (
              <video
                class="project-media-fallback"
                data-preview-src={mediaUrl}
                data-video-autoplay=""
                data-video-preview=""
                aria-label={`${mediaLabel} video preview`}
                controls={large}
                hidden
                loop
                muted
                playsinline
                preload="none"
                poster={project.image}
              />
            )
          }
        </>
      )
    ) : (
      <div class:list={["generated-project-art", { large }]} aria-hidden="true"></div>
    )
  }
  {badge && <span>{badge}</span>}
</div>

<script>
  const visibleVideos = new WeakSet<HTMLVideoElement>();
  let videoObserver: IntersectionObserver | undefined;

  function hydratePreview(video: HTMLVideoElement) {
    if (video.src || !video.dataset.previewSrc) return;
    video.src = video.dataset.previewSrc;
    video.load();
  }

  function canAutoPlayVideo() {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const connection = (navigator as Navigator & { connection?: { saveData?: boolean } }).connection;
    return !reduceMotion && !connection?.saveData;
  }

  function playVideo(video: HTMLVideoElement) {
    if (video.hidden || document.hidden) return;
    hydratePreview(video);
    video.play().catch(() => undefined);
  }

  function pauseVideo(video: HTMLVideoElement) {
    video.pause();
  }

  function syncVisibleVideo(video: HTMLVideoElement) {
    if (visibleVideos.has(video)) {
      playVideo(video);
    } else {
      pauseVideo(video);
    }
  }

  function isInViewport(video: HTMLVideoElement) {
    const rect = video.getBoundingClientRect();
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
    const viewportWidth = window.innerWidth || document.documentElement.clientWidth;
    return rect.width > 0 && rect.height > 0 && rect.bottom > 0 && rect.right > 0 && rect.top < viewportHeight && rect.left < viewportWidth;
  }

  function getVideoObserver() {
    if (videoObserver) return videoObserver;
    videoObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const video = entry.target;
          if (!(video instanceof HTMLVideoElement)) return;
          if (entry.isIntersecting && entry.intersectionRatio >= 0.18) {
            visibleVideos.add(video);
          } else {
            visibleVideos.delete(video);
          }
          syncVisibleVideo(video);
        });
      },
      {
        rootMargin: "0px",
        threshold: [0, 0.18, 0.55],
      }
    );
    return videoObserver;
  }

  function observeVideo(video: HTMLVideoElement) {
    if (video.dataset.autoplayBound === "true") return;
    video.dataset.autoplayBound = "true";

    if (!canAutoPlayVideo()) return;
    if (!("IntersectionObserver" in window)) {
      hydratePreview(video);
      playVideo(video);
      return;
    }

    getVideoObserver().observe(video);
  }

  function bindProjectMediaFallbacks() {
    document.querySelectorAll<HTMLImageElement>("img[data-video-fallback]:not([data-fallback-bound])").forEach((image) => {
      image.dataset.fallbackBound = "true";
      image.addEventListener(
        "error",
        () => {
          const fallback = image.nextElementSibling;
          if (!(fallback instanceof HTMLVideoElement)) return;
          image.hidden = true;
          fallback.hidden = false;
          hydratePreview(fallback);
          observeVideo(fallback);
          if (isInViewport(fallback)) {
            visibleVideos.add(fallback);
          }
          syncVisibleVideo(fallback);
        },
        { once: true }
      );
    });
  }

  function bindVideoPreviews() {
    document.querySelectorAll<HTMLVideoElement>("video[data-video-autoplay]").forEach((video) => {
      observeVideo(video);
    });
  }

  bindProjectMediaFallbacks();
  bindVideoPreviews();
  document.addEventListener("visibilitychange", () => {
    document.querySelectorAll<HTMLVideoElement>("video[data-video-autoplay]").forEach((video) => {
      syncVisibleVideo(video);
    });
  });
  document.addEventListener("astro:page-load", () => {
    bindProjectMediaFallbacks();
    bindVideoPreviews();
  });
</script>

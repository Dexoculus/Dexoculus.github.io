---
import type { Post, Project } from "@/lib/content";

type Props = {
  project: Project | Post;
  large?: boolean;
  autoplayPreview?: boolean;
};

const { project, large = false, autoplayPreview = true } = Astro.props;
const mediaLabel = "name" in project ? project.name : project.title;
const mediaUrl = project.mediaUrl || project.image;
const isVideo = project.mediaType === "video";
const canVideoFallback = Boolean(mediaUrl && !isVideo && mediaUrl.includes("github.com/user-attachments/assets/"));
const poster = isVideo ? project.image : undefined;
const shouldRenderVideo = isVideo && (large || autoplayPreview);
const isProject = "tools" in project;
const placeholderLabel = isProject ? "PROJECT RECORD" : "NOTE RECORD";
const placeholderTools = isProject ? project.tools.slice(0, 3) : project.tags.slice(0, 3);
---

<div class:list={["project-media", { large }]}>
  {
    mediaUrl ? (
      shouldRenderVideo ? (
        <video
          src={large ? mediaUrl : undefined}
          data-preview-src={!large ? mediaUrl : undefined}
          data-video-autoplay=""
          data-video-preview={!large ? "" : undefined}
          aria-label={`${mediaLabel} video preview`}
          autoplay={!large}
          controls={large}
          loop
          muted
          playsinline
          preload={large ? "metadata" : "none"}
          poster={poster}
        />
      ) : isVideo && poster ? (
        <img src={poster} alt="" loading="lazy" decoding="async" fetchpriority="low" />
      ) : (
        <>
          <img
            src={mediaUrl}
            alt={large ? `${mediaLabel} project media` : ""}
            loading={large ? undefined : "lazy"}
            decoding="async"
            fetchpriority={large ? "high" : "low"}
            data-video-fallback={canVideoFallback ? "github-attachment" : undefined}
          />
          {
            canVideoFallback && (
              <video
                class="project-media-fallback"
                data-preview-src={mediaUrl}
                data-video-autoplay=""
                data-video-preview=""
                aria-label={`${mediaLabel} video preview`}
                autoplay={!large}
                controls={large}
                hidden
                loop
                muted
                playsinline
                preload="none"
                poster={project.image}
              />
            )
          }
        </>
      )
    ) : (
      <div class:list={["project-record-art", { large }]}>
        <span>{placeholderLabel}</span>
        <strong>{mediaLabel}</strong>
        {placeholderTools.length > 0 && <small>{placeholderTools.join(" / ")}</small>}
      </div>
    )
  }
  {isVideo && !shouldRenderVideo && <span class="media-play-indicator" aria-hidden="true"></span>}
</div>

<script>
  const visibleVideos = new Set<HTMLVideoElement>();
  let videoObserver: IntersectionObserver | undefined;

  function hydratePreview(video: HTMLVideoElement) {
    if (video.src || !video.dataset.previewSrc) return;
    video.src = video.dataset.previewSrc;
    video.load();
  }

  function configureVideo(video: HTMLVideoElement) {
    video.muted = true;
    video.defaultMuted = true;
    video.playsInline = true;
  }

  function playPreview(video: HTMLVideoElement) {
    if (video.hidden || document.hidden) return;
    configureVideo(video);
    hydratePreview(video);
    video.play().catch(() => {});
  }

  function getVideoObserver() {
    if (videoObserver) return videoObserver;
    videoObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const video = entry.target;
          if (!(video instanceof HTMLVideoElement)) return;

          if (entry.isIntersecting && entry.intersectionRatio > 0) {
            visibleVideos.add(video);
            playPreview(video);
          } else {
            visibleVideos.delete(video);
            video.pause();
          }
        }
      },
      {
        rootMargin: "80px 0px",
        threshold: 0.01,
      }
    );
    return videoObserver;
  }

  function observeVideo(video: HTMLVideoElement) {
    if (video.dataset.autoplayBound === "true") return;
    video.dataset.autoplayBound = "true";
    configureVideo(video);

    if (!("IntersectionObserver" in window)) {
      playPreview(video);
      return;
    }

    getVideoObserver().observe(video);
  }

  function bindProjectMediaFallbacks() {
    document.querySelectorAll<HTMLImageElement>("img[data-video-fallback]:not([data-fallback-bound])").forEach((image) => {
      image.dataset.fallbackBound = "true";
      image.addEventListener(
        "error",
        () => {
          const fallback = image.nextElementSibling;
          if (!(fallback instanceof HTMLVideoElement)) return;
          image.hidden = true;
          fallback.hidden = false;
          observeVideo(fallback);
        },
        { once: true }
      );
    });
  }

  function bindVideoPreviews() {
    document.querySelectorAll<HTMLVideoElement>("video[data-video-autoplay]").forEach((video) => {
      observeVideo(video);
    });
  }

  function bindProjectMedia() {
    bindProjectMediaFallbacks();
    bindVideoPreviews();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bindProjectMedia, { once: true });
  } else {
    bindProjectMedia();
  }

  document.addEventListener("visibilitychange", () => {
    if (document.hidden) {
      visibleVideos.forEach((video) => video.pause());
      return;
    }

    visibleVideos.forEach(playPreview);
  });
  document.addEventListener("astro:page-load", bindProjectMedia);
</script>

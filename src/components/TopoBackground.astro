        <path class="grid-line" d="M1200 0 V306 M1248 0 V306 M1344 0 V306 M1392 0 V306 M1440 0 V306 M1488 0 V306" />
        <path class="grid-row" d="M1152 92 H1536 M1152 184 H1536 M1152 276 H1536" />
      </g>
      <g class="grid-sector grid-sector-mid-left">
        <path class="grid-line grid-line-major" d="M72 336 V640 M240 336 V640" />
        <path class="grid-line" d="M120 336 V640 M168 336 V640 M288 336 V640" />
        <path class="grid-row grid-row-soft" d="M72 420 H336 M72 504 H336 M72 588 H336" />
      </g>
      <g class="grid-sector grid-sector-mid-right">
        <path class="grid-line grid-line-major" d="M1360 336 V640 M1528 336 V640" />
        <path class="grid-line" d="M1312 336 V640 M1408 336 V640 M1456 336 V640 M1504 336 V640" />
        <path class="grid-row grid-row-soft" d="M1264 420 H1528 M1264 504 H1528 M1264 588 H1528" />

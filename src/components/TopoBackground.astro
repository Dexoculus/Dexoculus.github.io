    <g class="dot-matrix-layer">
      <rect class="dot-matrix" x="58" y="344" width="244" height="150" fill="url(#tactical-dot-matrix)" />
      <rect class="dot-matrix" x="1298" y="344" width="244" height="150" fill="url(#tactical-dot-matrix)" />
      <rect class="dot-matrix dot-matrix-soft" x="96" y="722" width="292" height="118" fill="url(#tactical-dot-matrix)" />
      <rect class="dot-matrix dot-matrix-soft" x="1212" y="722" width="292" height="118" fill="url(#tactical-dot-matrix)" />

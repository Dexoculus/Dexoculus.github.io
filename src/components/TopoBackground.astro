      </pattern>
      <pattern id="tactical-dot-matrix" width="18" height="18" patternUnits="userSpaceOnUse">
        <circle class="dot-stroke" cx="2" cy="2" r="1.05" />
      </pattern>
      <linearGradient id="tactical-fade" x1="0" x2="1" y1="0" y2="0">
        <stop class="fade-stop-edge" offset="0" />
        <stop class="fade-stop-mid" offset="0.36" />
        <stop class="fade-stop-mid" offset="0.64" />
        <stop class="fade-stop-edge" offset="1" />
      </linearGradient>
    </defs>

    <rect class="tactical-sheet" x="0" y="0" width="1600" height="900" />

    <g class="tactical-bands">

      <g class="grid-sector grid-sector-bottom-left">
        <path class="grid-line grid-line-major" d="M96 654 V900 M320 654 V900" />
        <path class="grid-line" d="M144 654 V900 M192 654 V900 M240 654 V900 M368 654 V900" />
        <path class="grid-row grid-row-soft" d="M96 742 H416 M96 830 H416" />

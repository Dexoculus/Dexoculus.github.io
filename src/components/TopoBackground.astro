        <path class="grid-line grid-line-major" d="M1280 654 V900 M1504 654 V900" />
        <path class="grid-line" d="M1232 654 V900 M1360 654 V900 M1408 654 V900 M1456 654 V900" />
        <path class="grid-row grid-row-soft" d="M1184 742 H1504 M1184 830 H1504" />
      </g>

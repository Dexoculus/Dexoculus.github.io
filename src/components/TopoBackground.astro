      <rect class="tactical-hatch-fill" x="1320" y="-24" width="360" height="332" fill="url(#tactical-hatch)" />
      <rect class="tactical-hatch-fill tactical-hatch-muted" x="-80" y="654" width="360" height="282" fill="url(#tactical-hatch)" />
      <rect class="tactical-hatch-fill tactical-hatch-muted" x="1320" y="654" width="360" height="282" fill="url(#tactical-hatch)" />
    </g>

    <g class="blueprint-grid">
      <g class="grid-sector grid-sector-top-left">
        <path class="grid-line grid-line-major" d="M64 0 V306 M304 0 V306 M448 0 V306" />
        <path class="grid-line" d="M112 0 V306 M160 0 V306 M208 0 V306 M256 0 V306 M352 0 V306 M400 0 V306" />
